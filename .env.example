# API mode: mock | real | auto
EXPO_PUBLIC_API_MODE=mock

# Backend API base URL (used when mode is real/auto)
# 백엔드는 8080 포트에서 실행됨 (nginx 80포트는 별도 앱 서버 없음)
# - iOS/Android 직접 연결: EXPO_PUBLIC_API_BASE_URL=http://getdon-api.duckDNS.org:8080
# - Vercel 배포 (CORS/Mixed Content 자동 해결): EXPO_PUBLIC_API_BASE_URL=http://getdon-api.duckDNS.org:8080
#   → HTTPS 환경에서 HTTP URL 감지 시 자동으로 Vercel 프록시(/api/*) 경유
# - 로컬 web dev (CORS 해결): EXPO_PUBLIC_API_BASE_URL=http://localhost:3001
#   → 'pnpm run web:proxy'로 프록시 서버 별도 실행 필요
EXPO_PUBLIC_API_BASE_URL=http://getdon-api.duckDNS.org:8080

# Optional timeout in milliseconds
EXPO_PUBLIC_API_TIMEOUT_MS=8000

# Demo controls visibility
EXPO_PUBLIC_ENABLE_DEMO_CONTROLS=true

# Login screen test account hint visibility
EXPO_PUBLIC_SHOW_TEST_CREDENTIALS=true

# Console observability logging
EXPO_PUBLIC_ENABLE_OBSERVABILITY=true
