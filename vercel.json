{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm run export:web",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://getdon-api.duckDNS.org:8080/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
