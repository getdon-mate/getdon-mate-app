{
  "expo": {
    "name": "getdon-mate-app",
    "slug": "getdon-mate-app",
    "version": "1.0.0",
    "newArchEnabled": false,
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "resizeMode": "contain"
        }
      ]
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.anonymous.getdon-mate-app"
    },
    "android": {},
    "web": {
      "bundler": "metro",
      "output": "single"
    }
  }
}
