{
  "expo": {
    "name": "겟돈 메이트",
    "slug": "getdon-mate-app",
    "version": "1.0.0",
    "newArchEnabled": false,
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "getdonmate",
    "splash": {
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "resizeMode": "contain"
        }
      ]
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.YOURCOMPANY.getdonmate"
    },
    "android": {
      "package": "com.YOURCOMPANY.getdonmate"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    }
  }
}
